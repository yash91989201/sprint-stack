{
  "name": "sprint-stack",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.4.2",
      "zod": "^4.4.3",
      "@tanstack/react-query": "^5.101.2",
      "lucide-react": "^1.23.0",
      "next-themes": "^0.4.6",
      "sonner": "^2.0.7",
      "tailwindcss": "^4.3.2",
      "@orpc/server": "^1.14.6",
      "@orpc/client": "^1.14.6",
      "@orpc/openapi": "^1.14.6",
      "@orpc/zod": "^1.14.6",
      "@orpc/tanstack-query": "^1.14.6",
      "better-auth": "1.6.23",
      "@tanstack/react-form": "^1.33.0",
      "@types/react-dom": "^19.2.3",
      "tailwind-merge": "^3.6.0",
      "@better-auth/expo": "1.6.23"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "nx run-many -t dev",
    "build": "nx run-many -t build",
    "check-types": "nx run-many -t check-types",
    "dev:native": "nx run-many -t dev --projects=native",
    "dev:web": "nx run-many -t dev --projects=web",
    "db:push": "nx run-many -t db:push --projects=@sprint-stack/db",
    "db:studio": "nx run-many -t db:studio --projects=@sprint-stack/db",
    "db:generate": "nx run-many -t db:generate --projects=@sprint-stack/db",
    "db:migrate": "nx run-many -t db:migrate --projects=@sprint-stack/db",
    "db:start": "docker compose up -d postgres",
    "db:watch": "docker compose up postgres",
    "db:stop": "docker compose stop postgres",
    "db:down": "docker compose down postgres",
    "docker:build": "docker compose build",
    "docker:up": "docker compose up -d --build",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "check": "ultracite check",
    "fix": "ultracite fix"
  },
  "dependencies": {
    "@sprint-stack/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.2",
    "@sprint-stack/config": "workspace:*",
    "@types/node": "^22.13.14",
    "lefthook": "latest",
    "nx": "^23.0.1",
    "typescript": "^6",
    "ultracite": "7.9.2"
  },
  "packageManager": "bun@1.3.14"
}
